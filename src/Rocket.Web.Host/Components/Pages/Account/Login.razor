@page "/account/login"
@using Microsoft.Extensions.Localization
@using Rocket.Api.Contracts
@using Rocket.Interfaces
@using Rocket.Localization.Web
@inject IAuthenticationManager AuthenticationManager
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IStringLocalizer<LoginResource> StringLocalizer
@inherits Rocket.Web.Host.Infrastructure.BaseCancellableComponent

<MudPaper Class="p-4" elevation="2">
    <MudText
        Color="Color.Primary"
        GutterBottom
        Typo="Typo.h5">
        @StringLocalizer["LoginTitle"]
    </MudText>
    <BottleRocketLoadingOverlay IsLoading="@_isLoading">
        <MudForm
            Model="@_accountLoginRequest"
            @ref="_form">
            <MudGrid Justify="Justify.Center">
                <MudItem xs="12" sm="8" md="4">
                    <MudTextField
                        T="string"
                        Label="@StringLocalizer["LoginUserNameFieldHeader"]"
                        HelperText="@StringLocalizer["LoginUserNameFieldHint"]"
                        Required="true"
                        RequiredError="@StringLocalizer["LoginUserNameFieldRequiredError"]"
                        Disabled="@(_isLoading)"
                        @bind-Value="_accountLoginRequest.Username"
                        For="@(() => _accountLoginRequest.Username)"
                        OnlyValidateIfDirty/>
                </MudItem>
                <MudFlexBreak/>
                <MudItem xs="12" sm="8" md="4">
                    <MudTextField
                        T="string"
                        InputType="InputType.Password"
                        Label="@StringLocalizer["LoginPasswordFieldHeader"]"
                        HelperText="@StringLocalizer["LoginPasswordFieldHint"]"
                        Required="true"
                        RequiredError="@StringLocalizer["LoginPasswordFieldRequiredError"]"
                        Disabled="@(_isLoading)"
                        @bind-Value="_accountLoginRequest.Password"
                        For="@(() => _accountLoginRequest.Password)"
                        OnlyValidateIfDirty/>
                </MudItem>
            </MudGrid>
            <MudGrid Justify="Justify.FlexEnd">
                <MudItem>
                    <MudButton
                        Variant="Variant.Outlined"
                        Color="Color.Primary"
                        Disabled="@(_isLoading)"
                        Class="mt-4 mr"
                        OnClick="@HandleLoginAsync">
                        @StringLocalizer["LoginSubmitCaption"]
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </BottleRocketLoadingOverlay>
</MudPaper>

@code {

    MudForm _form;

    private bool _isLoading;

    private readonly AccountLoginRequest _accountLoginRequest = new();
    
    [SupplyParameterFromQuery]
    public string ReturnUrl { get; set; }

    private async Task HandleLoginAsync()
    {
        await
            _form
                .Validate();

        if (_form.IsValid)
        {
            _isLoading = true;
            StateHasChanged();

            try
            {
                var success =
                    await
                        AuthenticationManager
                            .LoginAsync(
                                _accountLoginRequest.Username,
                                _accountLoginRequest.Password,
                                BaseCancellationToken
                            );

                if (success)
                {
                    await
                        Task.Delay(100);

                    NavigationManager
                        .NavigateTo(
                            !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/",
                            replace: true
                            //forceLoad: true
                        );
                }
                else
                {
                    throw new Exception(StringLocalizer["LoginInvalidCredentialsError"].Value);
                }
            }
            catch (Exception ex)
            {
                Snackbar
                    .Add(
                        ex.Message,
                        Severity.Error
                    );
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

}