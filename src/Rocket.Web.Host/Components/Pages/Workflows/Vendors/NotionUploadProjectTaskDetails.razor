@page "/MyWorkflow/Notion/ProjectTask/{workflowId}/AddStep"
@page "/MyWorkflow/Notion/ProjectTask/{workflowId}/Steps/{parentStepId}/AddStep"
@page "/MyWorkflow/Notion/ProjectTask/{workflowId}/Steps/{stepId}/UpdateStep"
@using Rocket.Notion.Contracts
@using Rocket.Notion.Domain
@using Rocket.Web.Host.Infrastructure
@inject IWebHostErrorHandler WebHostErrorHandler

@using Rocket.Web.Client
@inject IApiRequestManager ApiRequestManager
@inherits Rocket.Web.Host.Infrastructure.BaseSecureCancellableComponent

<BottleRocketLoadingOverlay IsLoading="@_isLoading">
    <UpdateWorkflowStepWrapper
        @ref="_wrapper"
        T="NotionUploadProjectTaskWorkflowStepSpecifics"
        WorkflowStepName="Upload project task to Notion"
        WorkflowId="@WorkflowId"
        ParentStepId="@ParentStepId"
        RequiresConnectorCode="@NotionDomainConstants.ConnectorCode"
        OnConnectorIdChanged="ConnectorChangedAsync"
        StepId="@StepId"
        Context="stepSpecifics">
        <MudGrid>
            <MudItem sm="12" lg="6">
                <MudSelect
                    T="NotionDataSourceSummary"
                    Label=@(_isLoading ? "Loading..." : "Select a data source")
                    @bind-Value="@_dataSourceSummary"
                    @bind-Value:after="() => DataSourceChangedAsync(stepSpecifics)"
                    Disabled="@_isLoading"
                    Clearable
                    Required
                    RequiredError="Data source is required">
                    @foreach (var dataSource in _dataSources ?? [])
                    {
                        <MudSelectItem
                            T="NotionDataSourceSummary"
                            Value="@dataSource"
                        >
                            @dataSource.DataSourceName
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudFlexBreak/>
            <MudItem sm="12" lg="6">
                <MudSelect
                    T="NotionDataSourceProperty"
                    Label=@(_isLoading ? "Loading..." : "Select a field to set as the project code")
                    @bind-Value="@_projectCodeColumnSelected"
                    @bind-Value:after="() => ProjectCodeColumnChangedAsync(stepSpecifics)"
                    Disabled="@(_isLoading || string.IsNullOrEmpty(_connectorId))"
                    Clearable
                >
                    @foreach (var dataSourceProperty in _dataSourceProperties ?? [])
                    {
                        <MudSelectItem
                            T="NotionDataSourceProperty"
                            Value="@dataSourceProperty">
                            @dataSourceProperty.Name
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem sm="12" lg="6">
                <MudSelect
                    T="NotionDataSourceProperty"
                    Label=@(_isLoading ? "Loading..." : "Select a field to set as the task name")
                    @bind-Value="@_taskColumnSelected"
                    @bind-Value:after="() => TaskColumnChangedAsync(stepSpecifics)"
                    Disabled="@(_isLoading || string.IsNullOrEmpty(_connectorId))"
                    Clearable
                >
                    @foreach (var dataSourceProperty in _dataSourceProperties ?? [])
                    {
                        <MudSelectItem
                            T="NotionDataSourceProperty"
                            Value="@dataSourceProperty">
                            @dataSourceProperty.Name
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem sm="12" lg="6">
                <MudSelect
                    T="NotionDataSourceProperty"
                    Label=@(_isLoading ? "Loading..." : "Select a field to set as the due date")
                    @bind-Value="@_dueDateColumnSelected"
                    @bind-Value:after="() => DueDateColumnChangedAsync(stepSpecifics)"
                    Disabled="@(_isLoading || string.IsNullOrEmpty(_connectorId))"
                    Clearable
                >
                    @foreach (var dataSourceProperty in _dataSourceProperties ?? [])
                    {
                        <MudSelectItem
                            T="NotionDataSourceProperty"
                            Value="@dataSourceProperty">
                            @dataSourceProperty.Name
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem sm="12" lg="6">
                <MudSelect
                    T="NotionDataSourceProperty"
                    Label=@(_isLoading ? "Loading..." : "Select a field to set as the estimated time")
                    @bind-Value="@_estTimeColumnSelected"
                    @bind-Value:after="() => EstTimeColumnChangedAsync(stepSpecifics)"
                    Disabled="@(_isLoading || string.IsNullOrEmpty(_connectorId))"
                    Clearable
                >
                    @foreach (var dataSourceProperty in _dataSourceProperties ?? [])
                    {
                        <MudSelectItem
                            T="NotionDataSourceProperty"
                            Value="@dataSourceProperty">
                            @dataSourceProperty.Name
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </UpdateWorkflowStepWrapper>
</BottleRocketLoadingOverlay>

@code {

    [Parameter]
    public string WorkflowId { get; set; }

    [Parameter]
    public string ParentStepId { get; set; }

    [Parameter]
    public string StepId { get; set; }

    private bool _isLoading;

    private string _connectorId;

    private UpdateWorkflowStepWrapper<NotionUploadProjectTaskWorkflowStepSpecifics> _wrapper;

    private NotionDataSourceSummary _dataSourceSummary;

    private NotionDataSourceProperty _projectCodeColumnSelected;

    private NotionDataSourceProperty _taskColumnSelected;

    private NotionDataSourceProperty _dueDateColumnSelected;

    private NotionDataSourceProperty _estTimeColumnSelected;

    private IEnumerable<NotionDataSourceSummary> _dataSources = [];

    private IEnumerable<NotionDataSourceProperty> _dataSourceProperties = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await
                base
                    .OnInitializedAsync();

            _isLoading = true;
            StateHasChanged();

            await
                RefreshDataSourceAsync();
        }
        catch (Exception ex)
        {
            WebHostErrorHandler
                .HandleException(ex);
        }

        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshDataSourceAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(_connectorId))
            {
                _isLoading = true;
                StateHasChanged();

                var response =
                    await
                        ApiRequestManager
                            .GetNotionDataSourcesAsync(
                                new GetAllNotionDataSourcesRequest
                                {
                                    ConnectorId = _connectorId
                                },
                                BaseCancellationToken
                            );

                _dataSources =
                    (response?
                        .DataSources ?? [])
                    .ToList();

                _dataSourceSummary =
                    _dataSources
                        .FirstOrDefault(o => _wrapper?.StepSpecifics?.DataSourceId == o.DataSourceId);

                _dataSourceProperties =
                    _dataSources
                        .FirstOrDefault(o => o.DataSourceId == _dataSourceSummary?.DataSourceId)?
                        .Fields ?? [];

                _projectCodeColumnSelected =
                    (_dataSourceSummary?
                        .Fields ?? [])
                    .FirstOrDefault(o => o.Name == _wrapper?.StepSpecifics?.ProjectCodeColumn);

                _taskColumnSelected =
                    (_dataSourceSummary?
                        .Fields ?? [])
                    .FirstOrDefault(o => o.Name == _wrapper?.StepSpecifics?.TaskColumn);

                _dueDateColumnSelected =
                    (_dataSourceSummary?
                        .Fields ?? [])
                    .FirstOrDefault(o => o.Name == _wrapper?.StepSpecifics?.DueDateColumn);

                _estTimeColumnSelected =
                    (_dataSourceSummary?
                        .Fields ?? [])
                    .FirstOrDefault(o => o.Name == _wrapper?.StepSpecifics?.EstTimeColumn);
            }
            else
            {
                _dataSources = [];
            }
        }
        catch (Exception ex)
        {
            WebHostErrorHandler
                .HandleException(ex);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }

        StateHasChanged();
    }

    private async Task DataSourceChangedAsync(NotionUploadProjectTaskWorkflowStepSpecifics stepSpecifics)
    {
        stepSpecifics.DataSourceId =
            _dataSourceSummary?
                .DataSourceId;

        _dataSourceProperties =
            _dataSources
                .FirstOrDefault(o => o.DataSourceId == _dataSourceSummary?.DataSourceId)?
                .Fields ?? [];

        if (_dataSourceSummary?.DataSourceId == null)
        {
            await NullifyAllProperties();
        }
    }

    private async Task NullifyAllProperties()
    {
        _projectCodeColumnSelected = null;
        await ProjectCodeColumnChangedAsync(_wrapper?.StepSpecifics);
        _taskColumnSelected = null;
        await TaskColumnChangedAsync(_wrapper?.StepSpecifics);
        _dueDateColumnSelected = null;
        await DueDateColumnChangedAsync(_wrapper?.StepSpecifics);
        _estTimeColumnSelected = null;
        await EstTimeColumnChangedAsync(_wrapper?.StepSpecifics);
    }

    private async Task ConnectorChangedAsync(string connectorId)
    {
        _connectorId = connectorId;

        if (string.IsNullOrEmpty(connectorId))
        {
            _dataSourceSummary = null;
            await NullifyAllProperties();
        }

        await
            RefreshDataSourceAsync();
    }

    private async Task ProjectCodeColumnChangedAsync(NotionUploadProjectTaskWorkflowStepSpecifics stepSpecifics)
    {
        stepSpecifics.ProjectCodeColumn =
            _projectCodeColumnSelected?
                .Name;
    }

    private async Task TaskColumnChangedAsync(NotionUploadProjectTaskWorkflowStepSpecifics stepSpecifics)
    {
        stepSpecifics.TaskColumn =
            _taskColumnSelected?
                .Name;
    }

    private async Task DueDateColumnChangedAsync(NotionUploadProjectTaskWorkflowStepSpecifics stepSpecifics)
    {
        stepSpecifics.DueDateColumn =
            _dueDateColumnSelected?
                .Name;
    }

    private async Task EstTimeColumnChangedAsync(NotionUploadProjectTaskWorkflowStepSpecifics stepSpecifics)
    {
        stepSpecifics.EstTimeColumn =
            _estTimeColumnSelected?
                .Name;
    }

}