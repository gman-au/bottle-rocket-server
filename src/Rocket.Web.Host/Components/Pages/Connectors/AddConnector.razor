@page "/MyConnectors/Add"
@using Microsoft.Extensions.Localization
@using Rocket.Interfaces
@using Rocket.Localization.Web
@inherits Rocket.Web.Host.Infrastructure.BaseSecureCancellableComponent
@inject IEnumerable<ISkuConnector> ConnectorSkus
@inject IStringLocalizer<ConnectorsResource> StringLocalizer

<MudPaper Class="p-4" elevation="2">
    <MudText
        Align="Align.Center"
        Color="Color.Primary"
        GutterBottom
        Typo="Typo.h4">
        @StringLocalizer["ConnectorsAddTitle"]
    </MudText>
    <MudGrid Justify="Justify.FlexStart" Class="pa-4">
        @foreach (var connectorTemplate in ConnectorSkus ?? [])
        {
            <MudItem xs="12" sm="12" md="6" lg="4" xl="3">
                <MudCard Style="height:100%" Outlined>
                    <MudCardMedia
                        Image="@Assets[connectorTemplate.ImagePath]"
                        Height="100"/>
                    <MudCardContent>
                        <MudText
                            Typo="Typo.h6"
                            Color="Color.Secondary"
                        >
                            @connectorTemplate.Name
                        </MudText>
                    </MudCardContent>
                    <MudCardActions Class="justify-end">
                        <MudButton
                            Variant="Variant.Text"
                            Color="Color.Success"
                            OnClick="@(() => NavigateToAddAsync(connectorTemplate.Href))">
                            @StringLocalizer["ConnectorsAddConnectorsCaption"]
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

</MudPaper>

@code {

    private async Task NavigateToAddAsync(string href)
    {
        NavigationManager
            .NavigateTo(href);
    }
    
}