@page "/"

<MudPaper Class="p-4" elevation="2">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="6">
            <MudImage Fluid Src="@Assets["img/dashboard-title.png"]"/>
        </MudItem>
        <MudFlexBreak/>
        <MudItem xs="12">
            <DashboardSnapshot/>
        </MudItem>
    </MudGrid>

    <MudLink
        Target="_blank"
        Href="https://play.google.com/store/apps/details?id=au.com.gman.bottlerocket">
        <MudImage Class="carousel-badge" Src="@Assets["/img/google-play-badge.png"]"/>
    </MudLink>
</MudPaper>