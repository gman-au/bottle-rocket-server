@page "/Users/Add"
@using Microsoft.Extensions.Localization
@using Rocket.Api.Contracts.Users
@using Rocket.Interfaces
@using Rocket.Localization.Web
@using Rocket.Web.Client
@using Rocket.Web.Host.Components.Dialog
@using Rocket.Web.Host.Infrastructure
@inject IApiRequestManager ApiRequestManager
@inject IEmailAddressValidator EmailAddressValidator
@inject IWebHostErrorHandler WebHostErrorHandler
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IStringLocalizer<UsersResource> StringLocalizer
@inherits Rocket.Web.Host.Infrastructure.BaseSecureCancellableComponent

@if (_newModel != null)
{
    <MudPaper Class="p-4" elevation="2">
        <MudText
            Color="Color.Primary"
            GutterBottom
            Typo="Typo.h5">
            @StringLocalizer["UsersAddTitle"]
        </MudText>
        <BottleRocketLoadingOverlay IsLoading="@_isLoading">
            <MudForm
                Model="@_newModel"
                @ref="_form">
                <MudGrid>
                    <MudItem sm="12" lg="6" xl="4">
                        <MudTextField
                            T="string"
                            Label="@StringLocalizer["UsersUserNameFieldHeader"]"
                            Required="true"
                            Validation="@(new Func<string, bool>(EmailAddressValidator.IsValid))"
                            HelperText="@StringLocalizer["UsersUserNameFieldHint"]"
                            RequiredError="@StringLocalizer["UsersUserNameFieldHint"]"
                            Disabled="@(_isLoading)"
                            @bind-Value="_newModel.Username"
                            For="@(() => _newModel.Username)"
                            OnlyValidateIfDirty/>
                    </MudItem>
                    <MudItem sm="12" lg="6" xl="4">
                        <MudTextField
                            T="string"
                            Label="@StringLocalizer["UsersPasswordFieldHeader"]"
                            HelperText="@StringLocalizer["UsersPasswordFieldHint"]"
                            @ref="_pwField1"
                            InputType="InputType.Password"
                            @bind-Value="_newModel.NewPassword"
                            For="@(() => _newModel.NewPassword)"
                            Validation="@(new Func<string, IEnumerable<string>>(o => PasswordValidation.PasswordStrength(o, StringLocalizer)))"
                            RequiredError="@StringLocalizer["UsersPasswordFieldRequiredError"]"/>
                    </MudItem>
                    <MudItem sm="12" lg="6" xl="4">
                        <MudTextField
                            T="string"
                            Label="@StringLocalizer["UsersRepeatPasswordFieldHeader"]"
                            HelperText="@StringLocalizer["UsersRepeatPasswordFieldHint"]"
                            InputType="InputType.Password"
                            Validation="@(new Func<string, string>(PasswordMatch))"/>
                    </MudItem>
                </MudGrid>
                <MudGrid Class="align-start" Justify="Justify.FlexEnd">
                    <MudItem>
                        <MudButton
                            Variant="Variant.Outlined"
                            Color="Color.Success"
                            Disabled="@(_isLoading)"
                            OnClick="@SubmitAsync">
                            @StringLocalizer["UsersSubmitCaption"]
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        </BottleRocketLoadingOverlay>
    </MudPaper>
}

@code {

    MudForm _form;

    private bool _isLoading;
    private UserSpecifics _newModel = null;
    private MudTextField<string> _pwField1;

    [Parameter]
    public string Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await
                base
                    .OnInitializedAsync();

            _newModel = new UserSpecifics();

            _isLoading = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            WebHostErrorHandler
                .HandleException(ex);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SubmitAsync()
    {
        await
            _form
                .Validate();

        if (_form.IsValid)
        {
            _isLoading = true;
            StateHasChanged();

            try
            {
                var createUserResponse =
                    await
                        ApiRequestManager
                            .CreateUserAsync(
                                new CreateUserRequest
                                {
                                    Username = _newModel.Username,
                                    Password = _newModel.NewPassword,
                                    IsTheNewAdmin = false
                                },
                                BaseCancellationToken
                            );

                Snackbar
                    .Add(
                        StringLocalizer["UsersHasBeenAddedMessage"].Value,
                        Severity.Success
                    );
                
                if (!string.IsNullOrEmpty(createUserResponse?.QrCodeBase64))
                {
                    var dialog =
                        await
                            DialogService
                                .ShowAsync<UserQuickAuthDialog>(
                                    null,
                                    new DialogParameters
                                    {
                                        { "UserQuickAuthBase64", createUserResponse.QrCodeBase64 }
                                    }
                                );

                    await
                        dialog
                            .Result;
                }

                NavigationManager
                    .NavigateTo(
                        "/Users",
                        replace: true
                    );
            }
            catch (Exception ex)
            {
                WebHostErrorHandler
                    .HandleException(ex);
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    private string PasswordMatch(string arg)
    {
        if (_pwField1.Value != arg)
            return StringLocalizer["UsersRepeatPasswordFieldMatchError"];
        return null;
    }

}