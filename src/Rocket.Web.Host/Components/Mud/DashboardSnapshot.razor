@using Microsoft.Extensions.Localization
@using Rocket.Api.Contracts.Dashboard
@using Rocket.Localization
@using Rocket.Web.Client
@using Rocket.Web.Host.HubClients
@using Rocket.Web.Host.Infrastructure
@inject ICaptureHubClient CaptureHubClient
@inject ISnackbar Snackbar
@inject IApiRequestManager ApiRequestManager
@inject IWebHostErrorHandler WebHostErrorHandler
@inject IThemeService ThemeService
@inject IStringLocalizer<LocalizationResource> StringLocalizer
@implements IAsyncDisposable
@inherits Rocket.Web.Host.Infrastructure.BaseSecureCancellableComponent

<BottleRocketLoadingOverlay IsLoading="@_isLoading">
    @if (_dashboardSnapshot != null)
    {
        <MudGrid Justify="Justify.Center" Class="pa-4">
            <MudItem xs="12" sm="12" md="3" lg="3" Class="mb-4">
                <MudText Typo="Typo.h6" Class="text-center">
                    @StringLocalizer["DashboardScannedPagesCaption"]
                </MudText>
                <MudChart
                    ChartType="ChartType.Donut"
                    Width="100%"
                    Height="300px"
                    ChartOptions="@_vendorChartOptions"
                    InputData="@((_vendorData ?? []).ToArray())"
                    InputLabels="@((_vendorLabels ?? []).ToArray())">
                    <CustomGraphics>
                        <text
                            style="@("fill: var(--mud-palette-text-primary);")"
                            class="mud-donut-text mud-typography-h1"
                            x="50%"
                            y="50%">
                            @_dashboardSnapshot?.Scans?.TotalScansReceived
                        </text>
                    </CustomGraphics>
                </MudChart>
            </MudItem>
            <MudItem xs="12" sm="12" md="3" lg="3" Class="mb-4">
                <MudText Typo="Typo.h6" Class="text-center">
                    @StringLocalizer["DashboardStorageCaption"]
                </MudText>
                <MudChart
                    ChartType="ChartType.Donut"
                    Width="100%"
                    Height="300px"
                    ChartOptions="@_storageChartOptions"
                    InputData="@((_storageData ?? []).ToArray())"
                    InputLabels="@((_storageLabels ?? []).ToArray())">
                    <CustomGraphics>
                        <text
                            style="@($"fill: {_storageUsedStyleOfNote};")"
                            class="mud-donut-text mud-typography-h5"
                            x="50%"
                            y="40%">
                            @_storageUsedTextOfNote
                        </text>
                        <br/>
                        <text
                            style="@($"fill: {_storageAvailableStyleOfNote};")"
                            class="mud-donut-text mud-typography-h5"
                            x="50%"
                            y="60%">
                            @_storageAvailableTextOfNote
                        </text>
                    </CustomGraphics>
                </MudChart>
            </MudItem>
            @if (_dashboardSnapshot?.Lifecycle?.LifecyclesByGroup?.Count() > 0)
            {
                <MudFlexBreak/>
                <MudItem xs="12" Class="mb-4">
                    <MudText Typo="Typo.h6" Class="text-center">
                        Workflows
                    </MudText>
                    <MudChart
                        Nodes="@((_overviewNodes ?? []).ToList())"
                        Edges="@((_overviewEdges ?? []).ToList())"
                        ChartType="ChartType.Sankey"
                        Width="100%"
                        Height="300px"
                        ChartOptions="@_vendorChartOptions"
                        InputData="@((_vendorData ?? []).ToArray())"
                        InputLabels="@((_vendorLabels ?? []).ToArray())">
                    </MudChart>
                </MudItem>
            }
        </MudGrid>
    }
</BottleRocketLoadingOverlay>

@code {

    private const string StatusCompletedName = "COMPLETED";
    private const string StatusCompletedColor = "#239543";
    private const string StatusErroredName = "ERRORED";
    private const string StatusErroredColor = "#FE3F60";
    private const string StatusCancelledName = "CANCELLED";
    private const string StatusCancelledColor = "#D58001";
    private const string StatusRunningName = "RUNNING";
    private const string StatusRunningColor = "#107394";

    private IEnumerable<SankeyChartNode> _overviewNodes = Array.Empty<SankeyChartNode>();
    private IEnumerable<SankeyChartEdge> _overviewEdges = Array.Empty<SankeyChartEdge>();

    private IEnumerable<double> _vendorData = Array.Empty<double>();
    private IEnumerable<string> _vendorLabels = Array.Empty<string>();
    private readonly ChartOptions _vendorChartOptions = new();

    private IEnumerable<double> _storageData = Array.Empty<double>();
    private IEnumerable<string> _storageLabels = Array.Empty<string>();
    private readonly ChartOptions _storageChartOptions = new();

    private string _storageUsedTextOfNote = string.Empty;
    private string _storageUsedStyleOfNote = string.Empty;

    private string _storageAvailableTextOfNote = string.Empty;
    private string _storageAvailableStyleOfNote = string.Empty;

    private bool _isLoading = false;
    private bool _isConnected;
    private FetchDashboardResponse _dashboardSnapshot = null;

    protected override async Task OnAfterRenderAsync(
        bool firstRender
    )
    {
        if (!firstRender) return;

        try
        {
            CaptureHubClient.OnNewCaptureReceived += HandleDashboardUpdate;
            CaptureHubClient.OnNewExecutionUpdateReceived += HandleDashboardUpdate;
            CaptureHubClient.OnScanDeletedReceived += HandleDashboardUpdate;
            CaptureHubClient.OnExecutionDeletedReceived += HandleDashboardUpdate;

            await
                CaptureHubClient
                    .StartAsync();

            _isConnected =
                CaptureHubClient
                    .IsConnected;
        }
        catch (Exception ex)
        {
            WebHostErrorHandler
                .HandleException(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await
                base
                    .OnInitializedAsync();

            _isLoading = true;
            StateHasChanged();

            await
                LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            WebHostErrorHandler
                .HandleException(ex);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDashboardAsync()
    {
        _dashboardSnapshot =
            await
                ApiRequestManager
                    .GetDashboardSnapshotAsync(
                        BaseCancellationToken
                    );

        ApplyToLifecycleTotalsChart(_dashboardSnapshot);

        ApplyToVendorChart(_dashboardSnapshot);

        ApplyToStorageChart(_dashboardSnapshot);
    }

    private void ApplyToLifecycleTotalsChart(
        FetchDashboardResponse snapshot
    )
    {
        var lifecyclesByGroup =
            (snapshot?
                .Lifecycle?
                .LifecyclesByGroup ?? [])
            .ToList();

        var allWorkflowNodes =
            lifecyclesByGroup
                .Select(o => o.Workflow)
                .Distinct()
                .Select(
                    o =>
                        new SankeyChartNode
                        {
                            Name = o,
                            Column = 0
                        }
                )
                .ToList();

        for (var i = 0; i < allWorkflowNodes.Count; i++)
        {
            allWorkflowNodes
                    .ElementAt(i)
                    .Color =
                BottleRocketChartPalette
                    .Values
                    .ElementAt(i % BottleRocketChartPalette.Values.Count());
        }

        var allStatusNodes =
            lifecyclesByGroup
                .Select(o => o.Status)
                .Distinct()
                .Select(
                    o =>
                        new SankeyChartNode
                        {
                            Name = o,
                            Column = 1,
                            Color = MapStatusToColor(o)
                        }
                );

        _overviewNodes =
            allStatusNodes
                .Concat(allWorkflowNodes);

        _overviewEdges =
            lifecyclesByGroup
                .Select(
                    o =>
                        new SankeyChartEdge
                        {
                            Source = o.Workflow,
                            Target = o.Status,
                            Value = o.Count
                        }
                );
    }

    private void ApplyToVendorChart(
        FetchDashboardResponse snapshot
    )
    {
        const string vendorRocketbookName = "ROCKETBOOK";
        const string vendorRocketbookColor = "#A3CD39";
        const string vendorScribzeeName = "SCRIBZEE";
        const string vendorScribzeeColor = "#2F0890";

        _vendorData =
            (_dashboardSnapshot?.Scans?.ScansReceivedByVendor ?? [])
            .Select(o => (double)o.Scans);

        _vendorLabels =
            (_dashboardSnapshot?.Scans?.ScansReceivedByVendor ?? [])
            .Select(o => o.Vendor ?? string.Empty)
            .ToList();

        for (var i = 0; i < _vendorLabels.Count() && i < 20; i++)
        {
            _vendorChartOptions
                .ChartPalette[i] = Color.Surface.ToString();

            if (_vendorLabels.ElementAt(i)
                    ?.ToUpper() == vendorRocketbookName)
            {
                _vendorChartOptions
                    .ChartPalette[i] = vendorRocketbookColor;
            }

            if (_vendorLabels.ElementAt(i)
                    ?.ToUpper() == vendorScribzeeName)
            {
                _vendorChartOptions
                    .ChartPalette[i] = vendorScribzeeColor;
            }
        }
    }

    private void ApplyToStorageChart(
        FetchDashboardResponse snapshot
    )
    {
        const string statusUsedColor = "#18afe1";
        const string statusUsedName = "Used";
        const string statusAvailableColor = "#093d4e";
        const string statusAvailableName = "Available";

        _storageData =
            _dashboardSnapshot?.Storage != null
                ? new[]
                {
                    _dashboardSnapshot?.Storage?.UsedStorageBytes ?? 0D,
                    _dashboardSnapshot?.Storage?.AvailableStorageBytes ?? 0D
                }
                : [];

        _storageLabels =
            _dashboardSnapshot?.Storage != null
                ? new[]
                {
                    statusUsedName,
                    statusAvailableName
                }
                : [];

        _storageUsedTextOfNote = _dashboardSnapshot?.Storage?.UsedStorageFriendly;
        _storageUsedStyleOfNote = statusUsedColor;

        _storageAvailableTextOfNote = _dashboardSnapshot?.Storage?.AvailableStorageFriendly;
        _storageAvailableStyleOfNote = statusAvailableColor;

        _storageChartOptions.ChartPalette[0] = statusUsedColor;
        _storageChartOptions.ChartPalette[1] = statusAvailableColor;
    }

    private async Task HandleDashboardUpdate()
    {
        await
            InvokeAsync(
                async () =>
                {
                    try
                    {
                        _isLoading = true;
                        StateHasChanged();

                        await
                            LoadDashboardAsync();
                    }
                    catch (Exception ex)
                    {
                        WebHostErrorHandler
                            .HandleException(ex);
                    }
                    finally
                    {
                        _isLoading = false;
                        StateHasChanged();
                    }
                }
            );
    }

    public async ValueTask DisposeAsync()
    {
        // Clean up SignalR subscription
        CaptureHubClient.OnNewCaptureReceived -= HandleDashboardUpdate;
        CaptureHubClient.OnNewExecutionUpdateReceived -= HandleDashboardUpdate;

        await
            CaptureHubClient
                .StopAsync();
    }

    private static string MapStatusToColor(
        string status
    )
    {
        return status?.ToUpper() switch
        {
            StatusErroredName => StatusErroredColor,
            StatusCompletedName => StatusCompletedColor,
            StatusCancelledName => StatusCancelledColor,
            StatusRunningName => StatusRunningColor,
            _ => throw new ArgumentException("Invalid value for status")
        };
    }

}