<MudThemeProvider IsDarkMode="@IsDarkMode" Theme="MyTheme"/>

@code {

    private const string DefaultLetterSpacing = "0.14994px";
    private const string DefaultFontWeight = "500";
    private const string DefaultLineHeight = "1.6";

    private static readonly string[] DefaultFontFamily = { "Rubik" };

    [Parameter]
    public bool IsDarkMode { get; set; }

    public static MudTheme MyTheme => new()
    {
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = DefaultFontFamily,
                FontWeight = DefaultFontWeight,
                LineHeight = DefaultLineHeight,
                LetterSpacing = DefaultLetterSpacing
            },
            Body1 = new Body1Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing },
            Body2 = new Body2Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing },
            H1 = new H1Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing },
            H2 = new H2Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing },
            H3 = new H3Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing },
            H4 = new H4Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing },
            H5 = new H5Typography { FontWeight = DefaultFontWeight, LetterSpacing = DefaultLetterSpacing }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px"
        },
        PaletteLight = new PaletteLight
        {
            Primary = "#ce6c1c",
            Secondary = "#5a4911",
            Tertiary = "#4d791b",
            Info = "#107394",
            Success = "#239543",
            Warning = "#d58001",
            Error = "#fe3f60",
            AppbarBackground = "#a9c596",
            Background = "#eaf9e7",
            Surface = "#fff",
            DrawerBackground="#a9c596",
            DrawerText = "#093624"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#ffb375",
            Secondary = "#f3e7bf",
            Tertiary = "#497b2d",
            Info = "#18afe1",
            Success = "#3ecb6b",
            Warning = "#feb546",
            Error = "#fe3f60",
            AppbarBackground = "#315e2b",
            Background = "#0c1d11",
            Surface = "#162317",
            DrawerBackground="#315e2b",
            DrawerText = "#ddd"
        }
    };

}