@using Microsoft.Extensions.Localization
@using Rocket.Api.Contracts.Workflows
@using Rocket.Localization.Web
@inject IStringLocalizer<DialogResource> StringLocalizer

<MudDialog Class="p-2">
    <TitleContent>
        <MudText
            Color="Color.Primary"
            GutterBottom
            Typo="Typo.h5">
            @StringLocalizer["DialogDeleteWorkflowTitle"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText
            Typo="Typo.body1"
            Color="Color.Default">
            @StringLocalizer["DialogDeleteWorkflowBody"]
        </MudText>
        <MudText
            Class="mt-2 mb-2"
            Typo="Typo.h6"
            Color="Color.Info">
            @Workflow?.Name
        </MudText>
        <MudText
            Typo="Typo.body1"
            Color="Color.Error">
            @StringLocalizer["DialogDeleteWorkflowWarning"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton
            Variant="Variant.Outlined"
            OnClick="Cancel">
            @StringLocalizer["DialogDeleteWorkflowCancelCaption"]
        </MudButton>
        <MudButton
            Variant="Variant.Outlined"
            Color="Color.Error"
            OnClick="Submit">
            @StringLocalizer["DialogDeleteWorkflowSubmitCaption"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    
    [Parameter]
    public MyWorkflowSummary Workflow { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();

    protected override async Task OnParametersSetAsync()
    {
        await
            MudDialog
                .SetOptionsAsync(
                    new DialogOptions
                    {
                        FullWidth = true,
                        MaxWidth = MaxWidth.Medium,
                        BackgroundClass = "dialog-blur-backdrop"
                    }
                );
    }

}