@using Microsoft.Extensions.Localization
@using Rocket.Localization.Web
@inject IStringLocalizer<DialogResource> StringLocalizer

<MudDialog Class="p-2">
    <TitleContent>
        <MudText
            Color="Color.Primary"
            GutterBottom
            Typo="Typo.h5">
            @StringLocalizer["DialogDeleteScanTitle"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText 
            Typo="Typo.h6"
            Color="Color.Default"
        >
            @StringLocalizer["DialogDeleteScanBody"]
        </MudText>
        <MudText
            Typo="Typo.body1"
            Color="Color.Error"
        >
            @StringLocalizer["DialogDeleteScanWarning"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton
            Variant="Variant.Outlined"
            OnClick="Cancel">
            @StringLocalizer["DialogDeleteScanCancelCaption"]
        </MudButton>
        <MudButton
            Variant="Variant.Outlined"
            Color="Color.Error"
            OnClick="Submit">
            @StringLocalizer["DialogDeleteScanSubmitCaption"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    
    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();

    protected override async Task OnParametersSetAsync()
    {
        await
            MudDialog
                .SetOptionsAsync(
                    new DialogOptions
                    {
                        FullWidth = true,
                        MaxWidth = MaxWidth.Medium,
                        BackgroundClass = "dialog-blur-backdrop"
                    }
                );
    }

}